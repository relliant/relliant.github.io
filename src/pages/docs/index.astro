---
import { Image } from 'astro:assets'
import { Button, Card } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import publicationCover from '@/assets/intro_pic.png'

const meta = {
  title: 'Publications',
  description: 'Publications and related notes'
}
---

<PageLayout {meta}>
  <Button title='Back' href='/' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 mt-6 text-3xl font-medium sm:mt-10'>Publications</h1>
    </div>

    <section aria-label='Publications details' id='content' class='animate mt-8 max-w-none prose text-base md:min-w-[45ch]'>
      <h2 class='text-xl font-medium'>Preprint</h2>
      <div class='not-prose flex flex-col gap-4'>
        <Card
          heading='ATOM: A Training Framework for Humanoid Behavior Foundation Models with Imperfect Data'
          subheading='NeurIPS 2026 (Under Review)'
          date='2026'
        >
          <Image
            src={publicationCover}
            alt='ATOM paper preview'
            class='mb-3 mt-1 h-auto w-full rounded-xl border object-cover'
            loading='lazy'
          />
          <p class='text-muted-foreground'>
            Proposes a training framework for humanoid behavior foundation models under imperfect data
            conditions, grounded in our whole-body control deployment and Sim2Real validation results.
          </p>
          <div class='mt-3 flex flex-wrap gap-2'>
            <Button
              title='Paper preprint'
              href='https://www.researchgate.net/publication/405276407_ATOM_A_Training_Framework_for_Humanoid_Behavior_Foundation_Models_with_Imperfect_Data'
              target='_blank'
              variant='ahead'
            />
            <Button
              title='Project address'
              href='https://github.com/relliant/WholeBodyControl-PolicyTraining'
              target='_blank'
              variant='ahead'
            />
          </div>
        </Card>
      </div>
    </section>
  </main>
</PageLayout>
